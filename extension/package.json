{
  "name": "algoviz",
  "displayName": "Algorithm Visualizer",
  "description": "Benchmark, analyze complexity, and get AI explanations for any Python or C++ DSA / LeetCode solution.",
  "version": "5.0.0",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Education", "Visualization"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "algoViz.visualize",
        "title": "AlgoViz: Visualize Algorithm",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "algoViz.visualize",
          "when": "resourceExtname == .py || resourceExtname == .cpp",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Algorithm Visualizer",
      "properties": {
        "algoViz.aiApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for AI analysis (DeepSeek or OpenRouter). Store in User Settings — not workspace — to keep it private.",
          "scope": "application"
        },
        "algoViz.aiProvider": {
          "type": "string",
          "default": "deepseek",
          "enum": ["deepseek", "openrouter"],
          "enumDescriptions": [
            "Uses api.deepseek.com — great value, fast.",
            "OpenRouter — access to many models including GPT-4o, Claude, etc."
          ],
          "description": "AI provider for analysis."
        },
        "algoViz.aiModel": {
          "type": "string",
          "default": "",
          "description": "Model override. Leave blank to use the provider default (deepseek-chat / deepseek/deepseek-chat)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}